{
  "antigravity.agent.defaultModel": "gemini-3-pro",
  "antigravity.agent.planningMode": "review-driven",
  "antigravity.agent.autoSave": true,
  "antigravity.agent.concurrentAgents": 3,
  
  "antigravity.mcp.autoConnect": true,
  "antigravity.mcp.reconnectOnFailure": true,
  "antigravity.mcp.healthCheckInterval": 30,
  "antigravity.mcp.preferredServers": [
    "unity-mcp-coplay",
    "qwen-plus-unity-architect",
    "qwen-code-rapid-dev"
  ],
  
  "antigravity.terminal.autoExecution": "review-driven",
  "antigravity.terminal.allowList": [
    "ls",
    "dir",
    "git status",
    "git add",
    "git commit",
    "npm install",
    "docker ps",
    "docker logs"
  ],
  "antigravity.terminal.denyList": [
    "rm -rf",
    "git push --force",
    "sudo",
    "chmod 777"
  ],
  
  "antigravity.security.reviewJavaScript": true,
  "antigravity.security.sandboxMode": false,
  "antigravity.security.allowNetworkAccess": true,
  
  "antigravity.workspace.brain.path": ".gemini.antigravity.brain",
  "antigravity.workspace.brain.autoSync": true,
  "antigravity.workspace.brain.syncInterval": 60,
  
  "antigravity.workspace.rules.globalPath": "~/.gemini/GEMINI.md",
  "antigravity.workspace.rules.workspacePath": ".agent/rules",
  "antigravity.workspace.workflows.path": ".agent/workflows",
  
  "antigravity.unity.mcpEnabled": true,
  "antigravity.unity.autoRefreshAssetDatabase": true,
  "antigravity.unity.consoleLogs.maxLines": 100,
  
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  
  "files.associations": {
    "*.SKILL.md": "markdown",
    "QWEN.md": "markdown",
    "decisionslog.md": "markdown",
    "taskboard.md": "markdown"
  },
  
  "files.watcherExclude": {
    "**/Library/**": true,
    "**/Temp/**": true,
    "**/.vs/**": true,
    "**/obj/**": true,
    "**/bin/**": true
  },
  
  "search.exclude": {
    "**/node_modules": true,
    "**/Library": true,
    "**/Temp": true,
    "**/.git": true
  }
}
